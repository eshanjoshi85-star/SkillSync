generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  name            String
  bio             String?
  tokenBalance    Int       @default(10)
  violationCount  Int       @default(0)
  isBlockedUntil  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  skills               UserSkill[]
  quizVerifiedSkills   QuizVerifiedSkill[]
  tokenHistory         TokenHistory[]
  sessionsAsTeacher    Session[]           @relation("TeacherSessions")
  sessionsAsLearner    Session[]           @relation("LearnerSessions")
  quizAttempts         QuizAttempt[]

  @@map("users")
}

model Skill {
  id       String  @id @default(uuid())
  name     String  @unique
  category String

  userSkills UserSkill[]
  sessions   Session[]

  @@map("skills")
}

model UserSkill {
  id               String           @id @default(uuid())
  userId           String
  skillId          String
  type             SkillType
  proficiencyLevel ProficiencyLevel?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId, type])
  @@map("user_skills")
}

model TokenHistory {
  id        String           @id @default(uuid())
  userId    String
  amount    Int
  type      TransactionType
  sessionId String?
  createdAt DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id])

  @@map("token_history")
}

model Session {
  id               String        @id @default(uuid())
  teacherId        String
  learnerId        String
  skillId          String
  meetingLink      String?
  status           SessionStatus @default(PENDING)
  scheduledTime    DateTime
  durationMinutes  Int
  tokensTransferred Int          @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  teacher      User           @relation("TeacherSessions", fields: [teacherId], references: [id])
  learner      User           @relation("LearnerSessions", fields: [learnerId], references: [id])
  skill        Skill          @relation(fields: [skillId], references: [id])
  tokenHistory TokenHistory[]

  @@map("sessions")
}

enum SkillType {
  TEACH
  LEARN
}

enum ProficiencyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum TransactionType {
  EARNED_TEACHING
  SPENT_LEARNING
  SYSTEM_BONUS
  REFUND
}

enum SessionStatus {
  PENDING
  ACCEPTED
  DECLINED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model QuizAttempt {
  id             String   @id @default(uuid())
  userId         String
  skills         String[]
  questions      Json
  answers        Json
  score          Int
  totalQuestions Int
  passed         Boolean
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

/// Tracks quiz-verified skills (plain string, separate from TEACH/LEARN UserSkill system).
/// A skill is verified when the user passes (≥60%) a quiz containing that skill.
model QuizVerifiedSkill {
  id         String    @id @default(cuid())
  userId     String
  skill      String
  verified   Boolean   @default(false)
  verifiedAt DateTime?
  bestScore  Int       @default(0)
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skill])
  @@index([userId])
  @@map("quiz_verified_skills")
}
